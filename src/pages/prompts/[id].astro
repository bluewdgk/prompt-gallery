---
import { marked } from 'marked';
import Base from '../../layouts/Base.astro';
import TagBadge from '../../components/TagBadge.astro';
import { loadPrompts } from '../../lib/prompts';

export async function getStaticPaths() {
  const prompts = loadPrompts();
  return prompts.map((p) => ({ params: { id: p.id }, props: { prompt: p } }));
}

const { prompt } = Astro.props;

marked.setOptions({ gfm: true, breaks: false });
const promptHtml = marked.parse(prompt.prompt) as string;
const responseHtml = prompt.response ? (marked.parse(prompt.response) as string) : null;

const dateFormatted = new Date(prompt.date).toLocaleDateString('ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const sourceLabel = prompt.source === 'code' ? 'Claude Code' : '웹 채팅';
---

<Base title={prompt.title} description={prompt.summary}>
  <div class="detail-page">
    <div class="breadcrumb">
      <a href="/">← 목록으로</a>
    </div>

    <header class="detail-header">
      <div class="meta-row">
        <span class={`source-badge source-${prompt.source}`}>{sourceLabel}</span>
        <time class="meta-date">{dateFormatted}</time>
      </div>
      <h1>{prompt.title}</h1>
      <p class="summary">{prompt.summary}</p>
      <div class="tags">
        {prompt.tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
      {prompt.sessionRef && (
        <p class="session-ref">
          세션 참조: <code>{prompt.sessionRef}</code>
        </p>
      )}
    </header>

    <section class="block prompt-block">
      <h2 class="block-label">프롬프트</h2>
      <div class="prose" set:html={promptHtml} />
    </section>

    {responseHtml && (
      <section class="block response-block">
        <h2 class="block-label">응답</h2>
        <div class="prose" set:html={responseHtml} />
      </section>
    )}
  </div>
</Base>

<style is:global>
  /* Prose (markdown) styles */
  .prose { color: var(--text); line-height: 1.7; }
  .prose h1, .prose h2, .prose h3, .prose h4 {
    font-weight: 600;
    margin: 1.4em 0 0.6em;
    line-height: 1.3;
  }
  .prose h1 { font-size: 1.5rem; }
  .prose h2 { font-size: 1.25rem; }
  .prose h3 { font-size: 1.05rem; }
  .prose p { margin: 0.75em 0; }
  .prose ul, .prose ol { padding-left: 1.5em; margin: 0.75em 0; }
  .prose li { margin: 0.3em 0; }
  .prose blockquote {
    border-left: 3px solid var(--border);
    padding-left: 1em;
    color: var(--text-muted);
    margin: 1em 0;
  }
  .prose hr { border: none; border-top: 1px solid var(--border); margin: 1.5em 0; }
  .prose a { color: var(--accent); }
  .prose code:not(pre code) {
    font-family: ui-monospace, monospace;
    font-size: 0.875em;
    background: var(--tag-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--text);
  }
  .prose pre {
    background: #0d1117;
    color: #e6edf3;
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1em 0;
    font-size: 0.875rem;
    line-height: 1.6;
    border: 1px solid #30363d;
  }
  .prose pre code {
    background: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }
  .prose table { border-collapse: collapse; width: 100%; margin: 1em 0; }
  .prose th, .prose td {
    border: 1px solid var(--border);
    padding: 0.5em 0.75em;
    text-align: left;
  }
  .prose th { background: var(--bg-surface); font-weight: 600; }
</style>

<style>
  .detail-page { max-width: 800px; margin: 0 auto; }
  .breadcrumb { margin-bottom: 1.5rem; font-size: 0.9rem; }
  .detail-header { margin-bottom: 2rem; }
  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .source-badge {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.15rem 0.6rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .source-code { background: var(--badge-code-bg); color: var(--badge-code-text); }
  .source-web  { background: var(--badge-web-bg);  color: var(--badge-web-text); }
  .meta-date { font-size: 0.85rem; color: var(--text-muted); }
  h1 { font-size: 1.6rem; font-weight: 700; margin-bottom: 0.5rem; line-height: 1.3; }
  .summary { color: var(--text-muted); margin-bottom: 0.75rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.75rem; }
  .session-ref { font-size: 0.8rem; color: var(--text-muted); }
  .session-ref code {
    font-family: monospace;
    background: var(--tag-bg);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }
  .block {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    background: var(--bg-surface);
  }
  .block-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .prompt-block .block-label { color: var(--badge-code-text); }
  .response-block .block-label { color: var(--badge-web-text); }
</style>
